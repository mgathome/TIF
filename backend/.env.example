# =====================================================
# TIF — Backend env file
# =====================================================
# En dev : copiez en .env et remplissez.
# En prod : ces variables sont configurées dans Railway → Variables.

# ===== Server =====
NODE_ENV=development
PORT=4000

# Multi-origin supporté (séparé par virgule). Ex en prod :
# FRONTEND_URL=https://tif.vercel.app,https://www.tif.app
FRONTEND_URL=http://localhost:3000

# ===== Database =====
# Local       : postgres://postgres:postgres@localhost:5432/tif
# Neon (prod) : postgres://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tif

# ===== JWT =====
# Génère 64 caractères aléatoires :
#   PowerShell : -join ((1..64) | ForEach-Object {[char][int](Get-Random -Min 33 -Max 126)})
#   Web         : https://generate-secret.vercel.app/64
JWT_ACCESS_SECRET=replace_with_64_char_random_string
JWT_REFRESH_SECRET=replace_with_another_64_char_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ===== Stripe =====
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx

# En dev : généré par `stripe listen` (CLI)
# En prod : https://dashboard.stripe.com/test/webhooks après création de l'endpoint
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ===== Cookies =====
# En prod, ces valeurs sont gérées automatiquement (sameSite=none, secure=true)
# selon NODE_ENV. Inutile de les définir.
# COOKIE_DOMAIN=
# COOKIE_SECURE=false
